---
import BaseLayout from "../layouts/BaseLayout.astro";
import StockTable from "../components/StockTable.astro";
import { categories, type StockCategory } from "../data/stocks";

export function getStaticPaths() {
  return Object.entries(categories).map(([key, value]) => ({
    params: { category: value.slug },
    props: { categoryKey: key, category: value }
  }));
}

type Props = {
  categoryKey: StockCategory;
  category: {
    title: string;
    description: string;
    slug: string;
  };
};

const { categoryKey, category } = Astro.props;
const title = `${category.title}: AI Bubble Stock Tracker`;
const description = `${category.description} Compare AI exposure, bubble risk, key products, and signals to watch.`;
---

<BaseLayout title={title} description={description}>
  <main>
    <section class="hero">
      <div class="shell">
        <p class="eyebrow">AI infrastructure category</p>
        <h1>{category.title}</h1>
        <p class="lede">{category.description}</p>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Comparison table</p>
            <h2>Companies to Watch</h2>
          </div>
          <p>
            Monthly manual scores compare AI exposure, valuation narrative dependency, product relevance,
            and the signals most likely to change the bubble debate.
          </p>
        </div>
        <StockTable category={categoryKey} />
      </div>
    </section>
  </main>
</BaseLayout>
