---
import BaseLayout from "../layouts/BaseLayout.astro";
import BubbleProgressChart from "../components/BubbleProgressChart.astro";
import FaqList from "../components/FaqList.astro";
import MethodologyPanel from "../components/MethodologyPanel.astro";
import TimelineComparator from "../components/TimelineComparator.astro";

const title = "AI Bubble vs Dot-Com Bubble: Timeline and Chart";
const description =
  "Compare the AI bubble vs dot-com bubble with a timeline chart across infrastructure, market euphoria, revenue, search interest, and capital expenditure.";
const faqItems = [
  {
    question: "Is the AI bubble like the dot-com bubble?",
    answer:
      "The AI bubble vs dot-com bubble comparison is useful because both cycles began with a real technology shift before public-market expectations accelerated."
  },
  {
    question: "How is the AI bubble different from the dot-com bubble?",
    answer:
      "The AI cycle has more visible infrastructure revenue earlier, while the dot-com bubble had more unprofitable public companies and IPO speculation near the peak."
  },
  {
    question: "Where is AI compared with the dot-com bubble?",
    answer:
      "Our current reading places AI around Stage 3-4: market euphoria is visible, but revenue and capex evidence still matter."
  }
];
---

<BaseLayout title={title} description={description}>
  <main>
    <section class="hero">
      <div class="shell">
        <p class="eyebrow">Shareable research asset</p>
        <h1>AI Bubble vs Dot-Com Bubble</h1>
        <p class="lede">
          The AI bubble vs dot-com bubble comparison tracks the AI boom against the internet bubble cycle from 1994 to 2002.
          The timeline does not predict a crash; it compares observable signals across two technology investment cycles.
        </p>
      </div>
    </section>

    <section class="section highlight-section">
      <div class="shell">
        <BubbleProgressChart />
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <TimelineComparator />
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <MethodologyPanel />
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Methodology</p>
            <h2>What This Timeline Measures</h2>
          </div>
          <p>
            The comparison tracks infrastructure investment, public-market enthusiasm, valuation expansion,
            revenue realization, retail search interest, and capital expenditure dependency.
          </p>
        </div>
        <div class="category-grid">
          <div class="category-card"><h3>Infrastructure</h3><p>Chips, servers, data centers, networking, memory, storage, and power capacity.</p></div>
          <div class="category-card"><h3>Market</h3><p>Public-equity momentum, valuation expansion, IPO activity, and narrative broadening.</p></div>
          <div class="category-card"><h3>Revenue</h3><p>Whether the boom is supported by durable sales, margins, and cash flow.</p></div>
          <div class="category-card"><h3>Search</h3><p>Public attention and anxiety around terms such as AI bubble and AI stock bubble.</p></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <FaqList title="AI Bubble vs Dot-Com Bubble FAQ" items={faqItems} />
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Suggested citation</p>
            <h2>Reference This Chart</h2>
          </div>
          <p>
            AI Bubble Tracker, “AI Bubble vs Dot-Com Bubble Timeline,” updated monthly.
            https://aibubbletracker.com/ai-bubble-vs-dot-com-bubble/
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
