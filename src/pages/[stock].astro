---
import BaseLayout from "../layouts/BaseLayout.astro";
import StockLogo from "../components/StockLogo.astro";
import { stocks } from "../data/stocks";

export function getStaticPaths() {
  return stocks.map((stock) => ({
    params: { stock: stock.slug },
    props: { stock }
  }));
}

type Props = {
  stock: (typeof stocks)[number];
};

const { stock } = Astro.props;
const title = `${stock.company} AI Bubble: Stock, Valuation and Infrastructure Signals`;
const description = `Is ${stock.company} in an AI bubble? Track AI exposure, products, bubble risk, and the signals that matter for ${stock.ticker}.`;
---

<BaseLayout title={title} description={description}>
  <main>
    <section class="hero">
      <div class="shell hero-grid">
        <div>
          <p class="eyebrow">{stock.categories.join(" / ")} stock profile</p>
          <div class="stock-hero-title">
            <StockLogo stock={stock} size="lg" />
            <h1>Is {stock.company} in an AI Bubble?</h1>
          </div>
          <p class="lede">
            A neutral tracker for {stock.company}'s role in the AI infrastructure cycle, including AI exposure,
            product relevance, bubble risk, and the signals to watch next.
          </p>
        </div>
        <aside class="score-panel">
          <div class="score-row">
            <div>
              <p class="eyebrow">{stock.ticker}</p>
              <h2>Bubble Risk</h2>
            </div>
            <div class="score">{stock.riskScore}<small>/100</small></div>
          </div>
          <div class="meter rocket-meter" aria-label={`${stock.company} bubble risk score ${stock.riskScore} out of 100`}>
            <span style={`width:${stock.riskScore}%`}></span>
            <b style={`left:${stock.riskScore}%`} aria-hidden="true">🚀</b>
          </div>
          <p class="lede">AI exposure: {stock.aiExposure}</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="category-grid">
          <div class="category-card"><h3>AI Role</h3><p>{stock.keyProducts}</p></div>
          <div class="category-card"><h3>What Bulls Watch</h3><p>Revenue growth, durable margins, product adoption, and customer expansion.</p></div>
          <div class="category-card"><h3>What Bears Watch</h3><p>Valuation expansion, customer concentration, capex dependency, and cyclical oversupply.</p></div>
          <div class="category-card"><h3>Next Signal</h3><p>{stock.watchSignal}</p></div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
