---
import BaseLayout from "../layouts/BaseLayout.astro";
import FaqList from "../components/FaqList.astro";
import StockLogo from "../components/StockLogo.astro";
import { stocks } from "../data/stocks";

export function getStaticPaths() {
  return stocks.map((stock) => ({
    params: { stock: stock.slug },
    props: { stock }
  }));
}

type Props = {
  stock: (typeof stocks)[number];
};

const { stock } = Astro.props;
const title = `${stock.company} AI Bubble: Stock, Valuation and Infrastructure Signals`;
const description = `Is ${stock.company} in an AI bubble? Track AI exposure, products, bubble risk, and the signals that matter for ${stock.ticker}.`;
const faqItems = [
  {
    question: `Is ${stock.company} in an AI bubble?`,
    answer: `${stock.company} has an AI bubble risk score of ${stock.riskScore}/100. The score reflects AI exposure, product relevance, valuation narrative dependency, and the next signal to watch.`
  },
  {
    question: `What makes ${stock.company} part of the AI bubble debate?`,
    answer: `${stock.company} is tied to the AI infrastructure cycle through ${stock.keyProducts}. That makes ${stock.ticker} relevant to AI bubble, AI stock bubble, and semiconductor cycle searches.`
  },
  {
    question: `What should investors watch for ${stock.ticker}?`,
    answer: `The key signal for ${stock.ticker} is ${stock.watchSignal}. This is research context only and not investment advice.`
  }
];
---

<BaseLayout title={title} description={description}>
  <main>
    <section class="hero">
      <div class="shell hero-grid">
        <div>
          <p class="eyebrow">{stock.categories.join(" / ")} stock profile</p>
          <div class="stock-hero-title">
            <StockLogo stock={stock} size="lg" />
            <h1>Is {stock.company} in an AI Bubble?</h1>
          </div>
          <p class="lede">
            A neutral tracker for the {stock.company} AI bubble debate, including {stock.ticker} stock exposure,
            AI infrastructure products, bubble risk, and the signals to watch next.
          </p>
        </div>
        <aside class="score-panel">
          <div class="score-row">
            <div>
              <p class="eyebrow">{stock.ticker}</p>
              <h2>Bubble Risk</h2>
            </div>
            <div class="score">{stock.riskScore}<small>/100</small></div>
          </div>
          <div class="meter rocket-meter" aria-label={`${stock.company} bubble risk score ${stock.riskScore} out of 100`}>
            <span style={`width:${stock.riskScore}%`}></span>
            <b style={`left:${stock.riskScore}%`} aria-hidden="true">🚀</b>
          </div>
          <p class="lede">AI exposure: {stock.aiExposure}</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="category-grid">
          <div class="category-card"><h3>{stock.company} AI Bubble Risk</h3><p>{stock.keyProducts}</p></div>
          <div class="category-card"><h3>Why Bulls Defend {stock.ticker}</h3><p>Revenue growth, durable margins, product adoption, and customer expansion.</p></div>
          <div class="category-card"><h3>Why Bears See AI Bubble Risk</h3><p>Valuation expansion, customer concentration, capex dependency, and cyclical oversupply.</p></div>
          <div class="category-card"><h3>{stock.ticker} Signal to Watch</h3><p>{stock.watchSignal}</p></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <FaqList title={`${stock.company} AI Bubble FAQ`} items={faqItems} />
      </div>
    </section>
  </main>
</BaseLayout>
