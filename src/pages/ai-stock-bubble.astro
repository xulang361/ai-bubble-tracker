---
import BaseLayout from "../layouts/BaseLayout.astro";
import FaqList from "../components/FaqList.astro";
import StockTable from "../components/StockTable.astro";
import { categories } from "../data/stocks";

const title = "AI Stock Bubble: Nvidia, AMD, Intel, Micron, SK Hynix and Samsung";
const description =
  "Track AI stock bubble signals across GPU, CPU, memory, and storage companies including Nvidia, AMD, Intel, Micron, SanDisk, SK Hynix, and Samsung.";
const faqItems = [
  {
    question: "Are AI stocks in a bubble?",
    answer:
      "Some AI stocks show bubble-like signals, especially when valuation expansion outruns revenue growth. The AI stock bubble question should be judged stock by stock."
  },
  {
    question: "Which AI bubble stocks are tracked here?",
    answer:
      "The AI stock bubble watchlist tracks Nvidia, AMD, Intel, Micron, SanDisk, SK Hynix, and Samsung across GPU, CPU, memory, and storage categories."
  },
  {
    question: "Is Nvidia the whole AI stock bubble?",
    answer:
      "No. Nvidia is the anchor of the AI stock bubble debate, but HBM, DRAM, NAND, CPUs, data center storage, and capex suppliers also matter."
  }
];
---

<BaseLayout title={title} description={description}>
  <main>
    <section class="hero">
      <div class="shell">
        <p class="eyebrow">AI stock bubble tracker</p>
        <h1>AI Stock Bubble</h1>
        <p class="lede">
          The AI stock bubble debate is not just about Nvidia. The AI stock market bubble now spans GPUs, CPUs,
          HBM, DRAM, NAND, SSDs, foundry exposure, and the broader data center supply chain.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Stock clusters</p>
            <h2>AI Infrastructure Categories</h2>
          </div>
          <p>
            These categories match how AI capex flows through the semiconductor stack.
          </p>
        </div>
        <div class="category-grid">
          {
            Object.values(categories).map((category) => (
              <a class="category-card" href={`/${category.slug}/`}>
                <h3>{category.title}</h3>
                <p>{category.description}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Comparison table</p>
            <h2>AI Stock Bubble Watchlist</h2>
          </div>
          <p>
            Editorial scores compare AI exposure, product relevance, valuation narrative dependency,
            and the signals most likely to change the bubble debate.
          </p>
        </div>
        <StockTable />
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <FaqList title="AI Stock Bubble FAQ" items={faqItems} />
      </div>
    </section>
  </main>
</BaseLayout>
