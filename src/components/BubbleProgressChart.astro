        <text x="26" y="274">100%</text>
        <text x="26" y="222">200%</text>
        <text x="26" y="170">300%</text>
        <text x="26" y="118">400%</text>
        <text x="26" y="66">600%</text>
        <text x="52" y="370">T=0</text>
