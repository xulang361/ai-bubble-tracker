      <rect x="0" y="0" width="920" height="430" rx="10" fill="#fbfcfd" />
      <g stroke="#dce4ec" stroke-width="1">
        <line x1="72" y1="62" x2="848" y2="62" />
        <line x1="72" y1="114" x2="848" y2="114" />
        <line x1="72" y1="166" x2="848" y2="166" />
        <line x1="72" y1="218" x2="848" y2="218" />
        <line x1="72" y1="270" x2="848" y2="270" />
        <line x1="72" y1="322" x2="848" y2="322" />
