      <g stroke="#c6d0da" stroke-width="1">
        <line x1="72" y1="62" x2="72" y2="334" />
        <line x1="202" y1="62" x2="202" y2="334" />
        <line x1="332" y1="62" x2="332" y2="334" />
        <line x1="462" y1="62" x2="462" y2="334" />
        <line x1="592" y1="62" x2="592" y2="334" />
        <line x1="722" y1="62" x2="722" y2="334" />
        <line x1="848" y1="62" x2="848" y2="334" />
      </g>

      <path d={dotPath} fill="none" stroke="url(#blueStroke)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
      <path d={aiPath} fill="none" stroke="url(#redStroke)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />

      <g font-family="Inter, system-ui, sans-serif" font-size="13" fill="#5b6673">
