---
const xStart = 72;
const yBase = 322;
const chartWidth = 776;
const chartHeight = 260;
const maxYears = 6;
const maxReturn = 600;
const weeksPerYear = 52;

const point = (year: number, returnPct: number) => ({
  x: xStart + (year / maxYears) * chartWidth,
  y: yBase - (returnPct / maxReturn) * chartHeight
});

const interpolate = (anchors: Array<{ week: number; returnPct: number }>, week: number) => {
  const nextIndex = anchors.findIndex((anchor) => anchor.week >= week);
  if (nextIndex <= 0) return anchors[0].returnPct;
  const prev = anchors[nextIndex - 1];
  const next = anchors[nextIndex];
  const progress = (week - prev.week) / (next.week - prev.week);
  return prev.returnPct + (next.returnPct - prev.returnPct) * progress;
};

const weeklyNoise = (week: number, amplitude: number) =>
  Math.sin(week * 0.72) * amplitude + Math.sin(week * 0.19 + 1.7) * amplitude * 0.55;

const buildWeeklySeries = (
  anchors: Array<{ week: number; returnPct: number }>,
  maxWeek: number,
  amplitude: number
) =>
  Array.from({ length: maxWeek + 1 }, (_, week) => {
    const anchor = anchors.find((item) => item.week === week);
    const raw = anchor ? anchor.returnPct : interpolate(anchors, week) + weeklyNoise(week, amplitude);
    return {
      year: week / weeksPerYear,
      returnPct: Math.max(-8, Math.min(600, raw))
    };
  });

const toPath = (points: Array<{ year: number; returnPct: number }>) =>
  points
    .map(({ year, returnPct }, index) => {
      const { x, y } = point(year, returnPct);
      return `${index === 0 ? "M" : "L"} ${x.toFixed(1)} ${y.toFixed(1)}`;
    })
    .join(" ");

const dotComAnchors = [
  { week: 0, returnPct: 0 },
  { week: 9, returnPct: 18 },
  { week: 18, returnPct: 9 },
  { week: 27, returnPct: 42 },
  { week: 36, returnPct: 35 },
  { week: 46, returnPct: 68 },
  { week: 55, returnPct: 54 },
  { week: 63, returnPct: 82 },
  { week: 74, returnPct: 95 },
  { week: 84, returnPct: 72 },
  { week: 95, returnPct: 118 },
  { week: 105, returnPct: 106 },
  { week: 114, returnPct: 138 },
  { week: 124, returnPct: 126 },
  { week: 134, returnPct: 164 },
  { week: 145, returnPct: 145 },
  { week: 156, returnPct: 178 },
  { week: 169, returnPct: 155.1 },
  { week: 178, returnPct: 218 },
  { week: 188, returnPct: 255 },
  { week: 199, returnPct: 292 },
  { week: 209, returnPct: 268 },
  { week: 217, returnPct: 324 },
  { week: 227, returnPct: 306 },
  { week: 237, returnPct: 382 },
  { week: 246, returnPct: 456 },
  { week: 255, returnPct: 514 },
  { week: 263, returnPct: 581.7 },
  { week: 268, returnPct: 438 },
  { week: 275, returnPct: 512 },
  { week: 282, returnPct: 356 },
  { week: 290, returnPct: 452 },
  { week: 297, returnPct: 384 },
  { week: 305, returnPct: 286 },
  { week: 312, returnPct: 220 }
];

const aiAnchors = [
  { week: 0, returnPct: 0 },
  { week: 8, returnPct: 12 },
  { week: 16, returnPct: 4 },
  { week: 24, returnPct: 28 },
  { week: 32, returnPct: 22 },
  { week: 41, returnPct: 54 },
  { week: 49, returnPct: 46 },
  { week: 57, returnPct: 82 },
  { week: 66, returnPct: 76 },
  { week: 74, returnPct: 108 },
  { week: 82, returnPct: 96 },
  { week: 90, returnPct: 128 },
  { week: 99, returnPct: 112 },
  { week: 107, returnPct: 152 },
  { week: 115, returnPct: 142 },
  { week: 124, returnPct: 174 },
  { week: 132, returnPct: 168 },
  { week: 140, returnPct: 205 },
  { week: 149, returnPct: 184 },
  { week: 157, returnPct: 226 },
  { week: 163, returnPct: 198 },
  { week: 169, returnPct: 128.9 }
];

const dotComPoints = buildWeeklySeries(dotComAnchors, 312, 13);
const aiPoints = buildWeeklySeries(aiAnchors, 169, 9);

const dotPath = toPath(dotComPoints);
const aiPath = toPath(aiPoints);
const aiCurrent = point(3.25, 128.9);
const dotSamePeriod = point(3.25, 155.1);
const dotPeak = point(5.05, 581.7);
---

<section class="progress-chart" aria-label="Netscape internet bubble versus ChatGPT AI bubble progress chart">
  <div class="progress-chart-top">
    <div>
      <p class="eyebrow">Cycle progress chart</p>
      <h2>Netscape Internet Wave vs ChatGPT AI Wave</h2>
      <p>
        Both series are indexed from the launch moment. The AI line shows the first 858 trading days
        after ChatGPT, compared with the first 858 trading days after Netscape and the later dot-com peak.
      </p>
    </div>
    <div class="progress-stats" aria-label="Cycle comparison statistics">
      <div class="progress-stat blue">
        <span>Netscape cohort</span>
        <strong>+155%</strong>
        <small>after 858 trading days</small>
      </div>
      <div class="progress-stat red">
        <span>ChatGPT cohort</span>
        <strong>+129%</strong>
        <small>after 858 trading days</small>
      </div>
      <div class="progress-stat gold">
        <span>Dot-com peak</span>
        <strong>+582%</strong>
        <small>about 5.3 years after launch</small>
      </div>
    </div>
  </div>

  <div class="chart-shell">
    <svg viewBox="0 0 920 430" role="img" aria-labelledby="progressChartTitle progressChartDesc">
      <title id="progressChartTitle">AI bubble progress compared with the dot-com bubble</title>
